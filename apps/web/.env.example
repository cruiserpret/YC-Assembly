# Frontend → backend base URL. On Vercel, set this to your Railway
# backend's public URL (e.g. https://yc-assembly-api.up.railway.app).
NEXT_PUBLIC_ASSEMBLY_API_BASE=http://localhost:8000

# Set to "true" to expose the debug panel in the report UI. Off by default.
NEXT_PUBLIC_ASSEMBLY_DEBUG=

# Public mode: hides dev controls (mode picker, raw LLM-call count,
# raw cost USD) in the brief form. Defaults to TRUE in production;
# set to "false" for local dev when you want the legacy picker.
NEXT_PUBLIC_ASSEMBLY_PUBLIC_MODE=true
