# --- Env / secrets ---
.env
.env.*
!.env.example

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
.python-version
htmlcov/
.coverage
.coverage.*
*.log

# --- Node / Next ---
node_modules/
.next/
out/
.pnpm-store/
*.tsbuildinfo

# --- DB / data ---
*.sqlite
*.sqlite3
*.db
data/

# --- Phase 11A/B Amazon Reviews dataset (LOCAL ONLY) ---
# The provider reads from a local on-disk dataset path the operator
# points it at via ASSEMBLY_AMAZON_REVIEWS_DATA_DIR. Real category
# files (often gigabytes) must NEVER land in git. The tiny synthetic
# test fixtures under apps/api/tests/fixtures/amazon_reviews_provider/
# are explicitly re-included below so they stay tracked.
apps/api/_amazon_reviews_data/
amazon_reviews_2023/
*.jsonl.gz
*.parquet
!apps/api/tests/fixtures/amazon_reviews_provider/**/*.jsonl
!apps/api/tests/fixtures/amazon_reviews_provider/**/*.jsonl.gz

# Phase 11B per-run ingestion audit outputs (one file per category,
# overwritten on each run). The audit JSON shape itself is part of
# the contract — but the actual run output is too noisy for git.
apps/api/_audit/amazon_reviews_ingestion_11b_*.json

# --- IDE / OS ---
.idea/
.vscode/
.DS_Store
Thumbs.db

# --- Misc ---
dist/
build/
coverage/
data/

# --- Run snapshots (kept locally only; do not ship to the repo). ---
# Operator-report Markdown files in apps/api/_audit/ stay in git, but
# the per-run audit directories are too noisy + too large for the
# repo. Each run writes ~30 JSON files + a markdown report; the
# sample-report frontend page is fully self-contained so it doesn't
# need these on disk to render.
apps/api/_audit/live_runs/

# --- Frontend test artifacts ---
apps/web/coverage/
apps/web/playwright-report/
apps/web/test-results/

# Allow the PantryPulse sample transcript baked into the web app
!apps/web/src/data/
!apps/web/src/data/*.json
