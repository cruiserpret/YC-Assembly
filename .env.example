# --- Core ---
ASSEMBLY_ENV=development
ASSEMBLY_LOG_LEVEL=INFO

# --- Database ---
# Default Docker Compose host port is 5433 to avoid colliding with any local Postgres.
ASSEMBLY_DATABASE_URL=postgresql+asyncpg://assembly:assembly_dev@localhost:5433/assembly
ASSEMBLY_DATABASE_URL_SYNC=postgresql+psycopg://assembly:assembly_dev@localhost:5433/assembly

# --- Redis / job queue ---
ASSEMBLY_REDIS_URL=redis://localhost:6380/0

# --- LLM providers ---
# At least one must be set for Phase 3+. Phase 0/1 do not call any LLM.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- LLM routing (Phase 3+) ---
ASSEMBLY_LLM_PRIMARY_PROVIDER=anthropic
ASSEMBLY_LLM_SYNTHESIS_MODEL=claude-opus-4-7
ASSEMBLY_LLM_ROLEPLAY_MODEL=claude-sonnet-4-6

# --- Cost guardrails (Phase 3+) ---
ASSEMBLY_COST_SOFT_USD=0.50
# Phase 6.5: raised to 5.00 — full Phase 4–7 pipeline can exceed 2.00
ASSEMBLY_COST_HARD_USD=5.00

# --- Phase 6.5 simulation infrastructure ---
# Bounded concurrency for within-round agent calls. Within-sim parallelism is
# bounded by the cost-guard row lock; this knob is defense-in-depth + cross-sim
# throughput.
ASSEMBLY_SIMULATION_MAX_CONCURRENCY=3
# Default society size for queue-driven demo runs.
ASSEMBLY_SIMULATION_DEFAULT_SOCIETY_SIZE=6
# Phase 7 aggregation hook — disabled in 6.5; flipped on when Phase 7 ships.
ASSEMBLY_ENABLE_AGGREGATION=false
# Debug-only: expose GET /simulations/{id}/raw-state. Off in production.
ASSEMBLY_EXPOSE_RAW_STATE=false

# --- API server ---
ASSEMBLY_API_HOST=0.0.0.0
ASSEMBLY_API_PORT=8000
ASSEMBLY_CORS_ORIGINS=http://localhost:3000

# --- Frontend ---
NEXT_PUBLIC_API_BASE=http://localhost:8000

# --- Phase 5.5: real-world evidence retrieval (optional) ---
# Off by default. Set retrieval_enabled=true and pick a provider when you want
# Assembly to proactively search and extract real-world evidence beyond what
# the user pastes into the brief.
ASSEMBLY_RETRIEVAL_ENABLED=false

# Search provider for URL discovery. One of: mock | tavily | brave | serpapi
ASSEMBLY_SEARCH_PROVIDER=mock

# Page-extraction provider. One of: mock | httpx | firecrawl | jina
# httpx is the keyless fallback (uses BeautifulSoup over httpx). Firecrawl /
# Jina handle JS-heavy pages better but require keys.
ASSEMBLY_EXTRACTION_PROVIDER=httpx

# Provider keys (only set the ones for providers you've selected above):
TAVILY_API_KEY=
BRAVE_SEARCH_API_KEY=
SERPAPI_API_KEY=
FIRECRAWL_API_KEY=
JINA_API_KEY=
